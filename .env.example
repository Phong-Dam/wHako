# wHako Configuration

# Source website URL (default: docln.sbs)
BASE_URL=https://docln.sbs

# Enable auto-update (default: true in production)
AUTO_UPDATE=true

# Image cache limit in MB (default: 500)
IMAGE_CACHE_LIMIT=500

# Max history entries (default: 200)
MAX_HISTORY=200

# HTTP request timeout in ms (default: 30000)
REQUEST_TIMEOUT=30000

# Max retry attempts for HTTP requests (default: 3)
MAX_RETRIES=3
